# Ruta al mart SQLite generado por el Scrapper.
# Por defecto se resuelve a ../Scrapper/datos/comparadores/comparador.sqlite
# relativo a la raíz del frontend. Sobrescribe solo si la base vive en otra ruta.
CARTWISE_DB_PATH="../Scrapper/datos/comparadores/comparador.sqlite"

# Comando de Python usado para ejecutar el bridge SQLite (server/sqlite_bridge.py).
CARTWISE_PYTHON="python3"
